# AI Service Configuration

# Main API URL (Spring Boot backend)
MAIN_API_URL=http://localhost:8080

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Claude Model Settings
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2000

# Rule Engine Weights (must sum to 100)
RULE_WEIGHT_SPORT_MATCH=25
RULE_WEIGHT_FOLLOWER_REACH=25
RULE_WEIGHT_ENGAGEMENT=20
RULE_WEIGHT_INTEREST_TAGS=15
RULE_WEIGHT_GEOGRAPHIC=15

# College Football Data API (optional, for leverage calculator)
CFBD_API_KEY=YOUR_CFBD_KEY_HERE
